# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and never committed.

# Supabase project URL (https://<project-ref>.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase publishable key (starts with sb_publishable_...).
# Safe to expose to the browser. Used by the client-side Supabase SDK.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key (starts with sb_secret_...).
# Server-only — DO NOT prefix with NEXT_PUBLIC. Used by Server Actions
# that need admin privileges (e.g. generating invite magic links).
SUPABASE_SERVICE_ROLE_KEY=

# Resend API key (starts with re_...). Server-only.
# Used by Server Actions that send transactional email directly
# (separate from Supabase's auth emails, which also route through Resend
# but via SMTP configured in the Supabase dashboard).
RESEND_API_KEY=

# Email address that gets admin access to /admin.
ADMIN_EMAIL=
